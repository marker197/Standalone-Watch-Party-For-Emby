# Trakt 
# https://trakt.tv/oauth/applications → Create app
# Redirect URI: urn:ietf:wg:oauth:2.0:oob
TRAKT_CLIENT_ID=your_client_id_here
TRAKT_CLIENT_SECRET=your_client_secret_here

# Emby
# Settings  Advanced API Key
EMBY_URL=http://192.168.1.xxx:8096
EMBY_API_KEY=your_api_key_here

# Database
DB_USER=embytrakt
DB_PASSWORD=change_me_to_something_secure
DB_NAME=embytrakt

# Redis 
REDIS_PASSWORD=change_me_to_something_secure

# Security 
# 
JWT_SECRET_KEY=change_me 16 characters

# Optional: restrict to specific origins (comma-separated)
# ALLOWED_ORIGINS=http://localhost:8000

# Port 
SUITE_PORT=8000

# Logging 
LOG_LEVEL=INFO
